# Copy this file to ".env" and fill in your key:
#     cp .env.example .env
#
# Docker Compose automatically reads .env from this directory.

# === OpenAI (REQUIRED) ===
# Used by BOTH the backend (image-to-model, knowledge graph, personalization)
# and the modeling agent (LLM reasoning / RAG).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# === Optional overrides ===
# Only change these if you are not running on the default localhost ports.
# They are compiled into the frontend bundle at build time.
# DEPLOYMENT_URL=http://localhost:8080
# BACKEND_URL=http://localhost:9000/besser_api
# UML_BOT_WS_URL=ws://localhost:8765

# Comma-separated list of origins the backend accepts (CORS).
# CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
